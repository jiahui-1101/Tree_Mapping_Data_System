PORT=4174
SS3_VISITOR_STORE_PATH=.runtime/ss3-visitor-store.json
SS4_STORE_PATH=.runtime/ss4-store.json
SS3_AI_PROVIDER=mock
SS4_AI_PROVIDER=mock
SS3_AI_TIMEOUT_MS=8000

# Optional real AI providers. Leave blank for coursework-safe mock fallback.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional M1-C predictive maintenance database.
# Use memory for quick demo, or mysql to read/write shared MySQL tables.
M1C_MAINTENANCE_STORE=memory
# Optional SS4 database. Use json for demo, or mysql after importing docs/database/ss4_schema.sql.
SS4_STORE=json
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=tree_mapping_data_system

# Optional frontend Google Maps embed override.
VITE_GOOGLE_MAPS_EMBED_URL=https://www.google.com/maps?q=Taman%20Botani%20Johor%20Batu%20Pahat&output=embed

